# Copy this file to .env.local and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are exposed to the client bundle.
# Never put secrets in EXPO_PUBLIC_ variables.

# API
EXPO_PUBLIC_API_URL=http://10.0.2.2:5200

# Feature flags
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# Secrets (server-side only, never expose to client)
# API_SECRET=your-secret-here

EXPO_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
EXPO_PUBLIC_AUTH0_CLIENT_ID=your-client-id
EXPO_PUBLIC_AUTH0_AUDIENCE=https://your-api-audience
EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id